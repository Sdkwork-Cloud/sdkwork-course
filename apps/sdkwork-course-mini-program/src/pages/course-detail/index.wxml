<view class="container">
  <view class="course-header">
    <image src="{{course.thumbnail || '/assets/icons/course.png'}}" class="course-image"></image>
    <view class="course-info">
      <text class="course-title">{{course.title}}</text>
      <text class="course-subtitle">{{course.subtitle}}</text>
    </view>
  </view>
  
  <view class="course-stats">
    <view class="stat-item">
      <text class="stat-value">{{course.ratingScore || '暂无'}}</text>
      <text class="stat-label">课程评分</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{course.lessonsCount}}</text>
      <text class="stat-label">课时数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{course.studentsCount}}</text>
      <text class="stat-label">学习人数</text>
    </view>
  </view>
  
  <view class="course-description">
    <text class="section-title">课程简介</text>
    <text class="description-text">{{course.description || '暂无简介'}}</text>
  </view>
  
  <view class="course-actions">
    <button class="btn-enroll" bindtap="enroll">立即报名</button>
  </view>
</view>
