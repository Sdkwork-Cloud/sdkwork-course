/* Course detail page styles */
.course-header {
  position: relative;
  margin-bottom: 30rpx;
}

.course-image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
  border-radius: 12rpx;
}

.course-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 30rpx;
  border-radius: 0 0 12rpx 12rpx;
}

.course-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  display: block;
}

.course-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.course-stats {
  display: flex;
  justify-content: space-around;
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #3b82f6;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

.course-description {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.description-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
}

.course-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: white;
  border-top: 1rpx solid #eee;
}

.btn-enroll {
  background-color: #3b82f6;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  width: 100%;
}
