<view class="container">
  <view class="live-list">
    <view class="live-card" wx:for="{{sessions}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="live-status {{item.liveStatus}}">
        <text wx:if="{{item.liveStatus === 'live'}}">🔴 直播中</text>
        <text wx:elif="{{item.liveStatus === 'scheduled'}}">即将开始</text>
        <text wx:else>已结束</text>
      </view>
      <view class="live-info">
        <text class="live-title">{{item.title}}</text>
        <text class="live-time">{{item.scheduledStartAt}}</text>
      </view>
    </view>
    
    <view class="empty" wx:if="{{sessions.length === 0}}">
      <text>暂无直播课程</text>
    </view>
  </view>
</view>
