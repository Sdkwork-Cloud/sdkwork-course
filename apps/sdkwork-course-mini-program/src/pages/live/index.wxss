/* Live page styles */
.live-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.live-card {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.live-status {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.live-status.live {
  background-color: #fee2e2;
  color: #dc2626;
}

.live-status.scheduled {
  background-color: #dbeafe;
  color: #2563eb;
}

.live-status.ended {
  background-color: #f3f4f6;
  color: #6b7280;
}

.live-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.live-time {
  font-size: 24rpx;
  color: #666;
  display: block;
}
