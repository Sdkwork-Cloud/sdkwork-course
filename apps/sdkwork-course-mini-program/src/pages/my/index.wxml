<view class="container">
  <view class="user-info">
    <image src="{{userInfo.avatarUrl || '/assets/icons/my.png'}}" class="user-avatar"></image>
    <text class="user-name">{{userInfo.nickName || '未登录'}}</text>
  </view>
  
  <view class="menu-list">
    <view class="menu-item" bindtap="goToMyCourses">
      <text class="menu-title">我的课程</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToProgress">
      <text class="menu-title">学习进度</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToFavorites">
      <text class="menu-title">我的收藏</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="logout">
      <text class="menu-title logout">退出登录</text>
    </view>
  </view>
</view>
