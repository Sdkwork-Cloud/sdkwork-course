/* Courses page styles */
.search-bar {
  margin-bottom: 30rpx;
}

.search-bar input {
  background-color: white;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-card {
  display: flex;
  background-color: white;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.course-image {
  width: 200rpx;
  height: 150rpx;
  object-fit: cover;
}

.course-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.course-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.course-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}

.course-rating,
.course-lessons,
.course-students {
  font-size: 20rpx;
  color: #999;
}
