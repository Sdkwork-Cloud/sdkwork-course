<view class="container">
  <view class="header">
    <text class="title">欢迎来到在线课程平台</text>
  </view>
  
  <view class="menu-list">
    <view class="menu-item" bindtap="goToCourses">
      <image src="/assets/icons/course.png" class="menu-icon"></image>
      <view class="menu-content">
        <text class="menu-title">热门课程</text>
        <text class="menu-desc">探索我们的精品课程</text>
      </view>
    </view>
    
    <view class="menu-item" bindtap="goToLive">
      <image src="/assets/icons/live.png" class="menu-icon"></image>
      <view class="menu-content">
        <text class="menu-title">直播课堂</text>
        <text class="menu-desc">参与实时互动学习</text>
      </view>
    </view>
    
    <view class="menu-item" bindtap="goToMy">
      <image src="/assets/icons/my.png" class="menu-icon"></image>
      <view class="menu-content">
        <text class="menu-title">我的学习</text>
        <text class="menu-desc">查看学习进度</text>
      </view>
    </view>
  </view>
</view>
