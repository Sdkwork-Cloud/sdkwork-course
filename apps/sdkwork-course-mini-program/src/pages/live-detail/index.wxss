/* Live detail page styles */
.live-header {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.live-status {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.live-status.live {
  background-color: #fee2e2;
  color: #dc2626;
}

.live-status.scheduled {
  background-color: #dbeafe;
  color: #2563eb;
}

.live-status.ended {
  background-color: #f3f4f6;
  color: #6b7280;
}

.live-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.live-info {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.live-description {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.description-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
}

.live-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: white;
  border-top: 1rpx solid #eee;
}

.btn-join {
  background-color: #dc2626;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  width: 100%;
}

.btn-remind {
  background-color: #3b82f6;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  width: 100%;
}

.btn-replay {
  background-color: #6b7280;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  width: 100%;
}
